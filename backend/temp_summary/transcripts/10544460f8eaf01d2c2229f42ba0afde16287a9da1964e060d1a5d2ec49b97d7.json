  "segments": [
    {
      "start_seconds": 0,
      "end_seconds": 2,
      "text": "你知道为啥有些商场里的店"
    },
    {
      "start_seconds": 2,
      "end_seconds": 3,
      "text": "一个买的人都没有"
    },
    {
      "start_seconds": 3,
      "end_seconds": 5,
      "text": "却永远不会倒闭吗"
    },
    {
      "start_seconds": 5,
      "end_seconds": 5,
      "text": "我知道"
    },
    {
      "start_seconds": 5,
      "end_seconds": 6,
      "text": "是个洗钱"
    },
    {
      "start_seconds": 6,
      "end_seconds": 7,
      "text": "那老实"
    },
    {
      "start_seconds": 7,
      "end_seconds": 9,
      "text": "人家确实是正经做商业的"
    },
    {
      "start_seconds": 9,
      "end_seconds": 11,
      "text": "但他们就算一年不开张"
    },
    {
      "start_seconds": 11,
      "end_seconds": 12,
      "text": "也不会亏钱"
    },
    {
      "start_seconds": 12,
      "end_seconds": 13,
      "text": "为啥呀"
    },
    {
      "start_seconds": 13,
      "end_seconds": 14,
      "text": "大部分女装店"
    },
    {
      "start_seconds": 14,
      "end_seconds": 15,
      "text": "一年的毛利润"
    },
    {
      "start_seconds": 15,
      "end_seconds": 17,
      "text": "都在60%到85%之间"
    },
    {
      "start_seconds": 17,
      "end_seconds": 19,
      "text": "也就是说成本100多的衣服"
    },
    {
      "start_seconds": 19,
      "end_seconds": 20,
      "text": "它能卖到1000多"
    },
    {
      "start_seconds": 20,
      "end_seconds": 22,
      "text": "人家可能只卖20件衣服"
    },
    {
      "start_seconds": 22,
      "end_seconds": 24,
      "text": "就把半年的房租赚出来了"
    },
    {
      "start_seconds": 24,
      "end_seconds": 26,
      "text": "就算连续几个月都是负利润"
    },
    {
      "start_seconds": 26,
      "end_seconds": 27,
      "text": "到年底一算"
    },
    {
      "start_seconds": 27,
      "end_seconds": 29,
      "text": "毛利润仍然能用上百万"
    },
    {
      "start_seconds": 29,
      "end_seconds": 30,
      "text": "而那些奢侈品店"
    },
    {
      "start_seconds": 30,
      "end_seconds": 33,
      "text": "他们赚钱基本上靠的是VIP和会员质"
    },
    {
      "start_seconds": 33,
      "end_seconds": 34,
      "text": "他们的客户"
    },
    {
      "start_seconds": 34,
      "end_seconds": 36,
      "text": "甚至压根不会出现在店里"
    },
    {
      "start_seconds": 36,
      "end_seconds": 38,
      "text": "一般店里上新品的时候"
    },
    {
      "start_seconds": 38,
      "end_seconds": 41,
      "text": "店长会带人直接把东西送到VIP家里"
    },
    {
      "start_seconds": 41,
      "end_seconds": 42,
      "text": "让他们在家挑选"
    },
    {
      "start_seconds": 42,
      "end_seconds": 45,
      "text": "基本一次成交平均都是几十万"
    },
    {
      "start_seconds": 45,
      "end_seconds": 46,
      "text": "当是某钱小说吗"
    },
    {
      "start_seconds": 46,
      "end_seconds": 47,
      "text": "不仅如此"
    },
    {
      "start_seconds": 47,
      "end_seconds": 48,
      "text": "真正的大品牌"
    },
    {
      "start_seconds": 48,
      "end_seconds": 50,
      "text": "进驻商场的租金"
    },
    {
      "start_seconds": 50,
      "end_seconds": 51,
      "text": "会比其他店少很多"
    },
    {
      "start_seconds": 51,
      "end_seconds": 53,
      "text": "有的甚至没有租金"
    },
    {
      "start_seconds": 53,
      "end_seconds": 54,
      "text": "只需要给商场一些反点"
    },
    {
      "start_seconds": 54,
      "end_seconds": 56,
      "text": "卖的少就少给点"
    },
    {
      "start_seconds": 56,
      "end_seconds": 57,
      "text": "不卖的话就不收钱"
    },
    {
      "start_seconds": 57,
      "end_seconds": 59,
      "text": "甚至在消费淡季"
    },
    {
      "start_seconds": 59,
      "end_seconds": 61,
      "text": "商场会免费帮他们做些宣传"
    },
    {
      "start_seconds": 61,
      "end_seconds": 62,
      "text": "商场图啥呀"
    },
    {
      "start_seconds": 62,
      "end_seconds": 63,
      "text": "更流量啊"
    },
    {
      "start_seconds": 63,
      "end_seconds": 65,
      "text": "因为有这些顶榴垫铺在"
    },
    {
      "start_seconds": 65,
      "end_seconds": 68,
      "text": "商场才能保住自己高大盛的人设"
    },
    {
      "start_seconds": 68,
      "end_seconds": 69,
      "text": "才能吸引那些真正能花钱"
    },
    {
      "start_seconds": 69,
      "end_seconds": 71,
      "text": "会花钱的人进来"
    },
    {
      "start_seconds": 71,
      "end_seconds": 72,
      "text": "是我不配啦"
    },
    {
      "start_seconds": 72,
      "end_seconds": 73,
      "text": "话说"
    },
    {
      "start_seconds": 73,
      "end_seconds": 75,
      "text": "你知道商场里最容易倒闭的"
    },
    {
      "start_seconds": 75,
      "end_seconds": 76,
      "text": "是哪一种店吗"
    },
    {
      "start_seconds": 76,
      "end_seconds": 77,
      "text": "关注我"
    },
    {
      "start_seconds": 77,
      "end_seconds": 78,
      "text": "这些精彩不能错过"
    }
  ]
