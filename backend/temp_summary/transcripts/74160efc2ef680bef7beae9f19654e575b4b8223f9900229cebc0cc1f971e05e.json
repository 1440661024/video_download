{
  "source_type": "speech_to_text",
  "language": "zh",
  "fallback_used": true,
  "segments": [
    {
      "start_seconds": 0,
      "end_seconds": 2,
      "text": "看来兄弟们都误会卡纳威了"
    },
    {
      "start_seconds": 2,
      "end_seconds": 4,
      "text": "她是真没眼我没捞皮了"
    },
    {
      "start_seconds": 4,
      "end_seconds": 6,
      "text": "我纳威哥是去哪哪就是脱罗呀"
    },
    {
      "start_seconds": 6,
      "end_seconds": 7,
      "text": "这把韩华打7万"
    },
    {
      "start_seconds": 7,
      "end_seconds": 9,
      "text": "宙斯锁了一手上单威"
    },
    {
      "start_seconds": 9,
      "end_seconds": 10,
      "text": "多兰一击连经验都不敢闻"
    },
    {
      "start_seconds": 10,
      "end_seconds": 12,
      "text": "看来这大威人打小威"
    },
    {
      "start_seconds": 12,
      "end_seconds": 13,
      "text": "确实有说法"
    },
    {
      "start_seconds": 13,
      "end_seconds": 14,
      "text": "宙斯都三级了"
    },
    {
      "start_seconds": 14,
      "end_seconds": 15,
      "text": "多兰才补了四个刀"
    },
    {
      "start_seconds": 15,
      "end_seconds": 16,
      "text": "这才四分钟"
    },
    {
      "start_seconds": 16,
      "end_seconds": 17,
      "text": "宙斯就喊来队友跃躺"
    },
    {
      "start_seconds": 17,
      "end_seconds": 18,
      "text": "作为对那老大哥的卡纳威"
    },
    {
      "start_seconds": 18,
      "end_seconds": 20,
      "text": "舍不得自己的F6"
    },
    {
      "start_seconds": 20,
      "end_seconds": 21,
      "text": "就喊小弟Z卡去跃躺"
    },
    {
      "start_seconds": 21,
      "end_seconds": 23,
      "text": "这大野乏语中单抓人的"
    },
    {
      "start_seconds": 23,
      "end_seconds": 25,
      "text": "这在我们韩华都是假成变范了"
    },
    {
      "start_seconds": 25,
      "end_seconds": 26,
      "text": "抓完上路再抓下"
    },
    {
      "start_seconds": 26,
      "end_seconds": 28,
      "text": "这Z卡玩个眼穴可劲离我飞大个"
    },
    {
      "start_seconds": 28,
      "end_seconds": 30,
      "text": "飞哥看到对面都有走了"
    },
    {
      "start_seconds": 30,
      "end_seconds": 31,
      "text": "自己也不能过来"
    },
    {
      "start_seconds": 31,
      "end_seconds": 32,
      "text": "这安妮爸还是个小短腿"
    },
    {
      "start_seconds": 32,
      "end_seconds": 34,
      "text": "每次都是人家打完的他才走过来"
    },
    {
      "start_seconds": 34,
      "end_seconds": 36,
      "text": "既然抓不到来那就吃个冰"
    },
    {
      "start_seconds": 36,
      "end_seconds": 37,
      "text": "也不算搬来"
    },
    {
      "start_seconds": 37,
      "end_seconds": 38,
      "text": "看到这肯定会有兄弟问"
    },
    {
      "start_seconds": 38,
      "end_seconds": 40,
      "text": "七万的奇迹行者在干嘛"
    },
    {
      "start_seconds": 40,
      "end_seconds": 42,
      "text": "在我飞哥往下走的同时"
    },
    {
      "start_seconds": 42,
      "end_seconds": 44,
      "text": "欧呢就和我飞哥擦肩而过"
    },
    {
      "start_seconds": 44,
      "end_seconds": 45,
      "text": "削我哪位哥是吧"
    },
    {
      "start_seconds": 45,
      "end_seconds": 47,
      "text": "把中单当打野用自己闷头发育"
    },
    {
      "start_seconds": 47,
      "end_seconds": 49,
      "text": "然后刷坑就开始在槽里睡觉"
    },
    {
      "start_seconds": 49,
      "end_seconds": 51,
      "text": "真正挂机了两波冰的时间"
    },
    {
      "start_seconds": 51,
      "end_seconds": 53,
      "text": "睡醒了再来一个眼上蹲"
    },
    {
      "start_seconds": 53,
      "end_seconds": 55,
      "text": "不过这还有个真眼的钱也算"
    },
    {
      "start_seconds": 55,
      "end_seconds": 56,
      "text": "这边没白蹲"
    },
    {
      "start_seconds": 56,
      "end_seconds": 57,
      "text": "这把的姑妈也很懂"
    },
    {
      "start_seconds": 57,
      "end_seconds": 58,
      "text": "一看少爷来了"
    },
    {
      "start_seconds": 58,
      "end_seconds": 59,
      "text": "就立马闪现向前"
    },
    {
      "start_seconds": 59,
      "end_seconds": 60,
      "text": "肉身开头"
    },
    {
      "start_seconds": 60,
      "end_seconds": 60,
      "text": "戴头冲锋"
    },
    {
      "start_seconds": 60,
      "end_seconds": 61,
      "text": "把纳美打残了"
    },
    {
      "start_seconds": 61,
      "end_seconds": 62,
      "text": "就及时停手"
    },
    {
      "start_seconds": 62,
      "end_seconds": 64,
      "text": "把人头背到纳维嘴里吃"
    },
    {
      "start_seconds": 64,
      "end_seconds": 65,
      "text": "就为你一记"
    },
    {
      "start_seconds": 65,
      "end_seconds": 67,
      "text": "懂不懂我纳维哥的对内地位呀"
    },
    {
      "start_seconds": 67,
      "end_seconds": 68,
      "text": "这把的转着点"
    },
    {
      "start_seconds": 68,
      "end_seconds": 69,
      "text": "就是欧纳偷这边F6"
    },
    {
      "start_seconds": 69,
      "end_seconds": 71,
      "text": "像是打开了纳维的开关"
    },
    {
      "start_seconds": 71,
      "end_seconds": 71,
      "text": "欧纳抓上"
    },
    {
      "start_seconds": 71,
      "end_seconds": 72,
      "text": "纳维刷吃豆仁"
    },
    {
      "start_seconds": 72,
      "end_seconds": 73,
      "text": "抓下"
    },
    {
      "start_seconds": 73,
      "end_seconds": 74,
      "text": "纳维刷自己的F6"
    },
    {
      "start_seconds": 74,
      "end_seconds": 74,
      "text": "抓中"
    },
    {
      "start_seconds": 74,
      "end_seconds": 76,
      "text": "纳维在Z卡身后回城"
    },
    {
      "start_seconds": 76,
      "end_seconds": 77,
      "text": "等欧娜杀完了再赶过来"
    },
    {
      "start_seconds": 77,
      "end_seconds": 79,
      "text": "偷窝把我Z卡的炮车给吃了"
    },
    {
      "start_seconds": 79,
      "end_seconds": 81,
      "text": "坏了欧娜是真误了"
    },
    {
      "start_seconds": 81,
      "end_seconds": 84,
      "text": "原来打我纳维哥只需要偷一组F6就够了"
    },
    {
      "start_seconds": 84,
      "end_seconds": 85,
      "text": "打到现在"
    },
    {
      "start_seconds": 85,
      "end_seconds": 87,
      "text": "姑妈一看纳维智能不起来了就有点急了"
    },
    {
      "start_seconds": 87,
      "end_seconds": 89,
      "text": "一边一上去打个强化W"
    },
    {
      "start_seconds": 89,
      "end_seconds": 90,
      "text": "被开着来惊人一判到了"
    },
    {
      "start_seconds": 90,
      "end_seconds": 93,
      "text": "一个致命水盘让落后50刀的炉仙拿到了对位机上"
    },
    {
      "start_seconds": 93,
      "end_seconds": 96,
      "text": "看姑妈这表情那可真是难受急了"
    },
    {
      "start_seconds": 96,
      "end_seconds": 98,
      "text": "就看到对那最肥的AD都开始送了"
    },
    {
      "start_seconds": 98,
      "end_seconds": 99,
      "text": "我咒大哥也不装了"
    },
    {
      "start_seconds": 99,
      "end_seconds": 101,
      "text": "直接滚上去吃了安妮一套"
    },
    {
      "start_seconds": 101,
      "end_seconds": 104,
      "text": "看周思这表情又喝原来伤害这么高的吗"
    },
    {
      "start_seconds": 104,
      "end_seconds": 105,
      "text": "我亲爱的老大哥"
    },
    {
      "start_seconds": 105,
      "end_seconds": 106,
      "text": "打到24分钟"
    },
    {
      "start_seconds": 106,
      "end_seconds": 107,
      "text": "韩华是彻底迷糊了"
    },
    {
      "start_seconds": 107,
      "end_seconds": 109,
      "text": "一直在大龙坑转圈"
    },
    {
      "start_seconds": 109,
      "end_seconds": 110,
      "text": "玉石不绝打大龙"
    },
    {
      "start_seconds": 110,
      "end_seconds": 111,
      "text": "这味道实在太对了"
    },
    {
      "start_seconds": 111,
      "end_seconds": 112,
      "text": "这踢完打小龙"
    },
    {
      "start_seconds": 112,
      "end_seconds": 113,
      "text": "不敢打龙B团"
    },
    {
      "start_seconds": 113,
      "end_seconds": 115,
      "text": "那先把视野拍了也能理解"
    },
    {
      "start_seconds": 115,
      "end_seconds": 116,
      "text": "这踢完打小龙的同时"
    },
    {
      "start_seconds": 116,
      "end_seconds": 118,
      "text": "多兰的那耳都带到二塔了"
    },
    {
      "start_seconds": 118,
      "end_seconds": 119,
      "text": "这也能忍住不打龙的呀"
    },
    {
      "start_seconds": 119,
      "end_seconds": 120,
      "text": "最后那小龙打完了"
    },
    {
      "start_seconds": 120,
      "end_seconds": 122,
      "text": "多兰二塔也带掉了"
    },
    {
      "start_seconds": 122,
      "end_seconds": 123,
      "text": "韩华反倒是开始动龙了"
    },
    {
      "start_seconds": 123,
      "end_seconds": 125,
      "text": "这忙责不计不忙的走过来"
    },
    {
      "start_seconds": 125,
      "end_seconds": 126,
      "text": "同时多兰在一个TP"
    },
    {
      "start_seconds": 126,
      "end_seconds": 128,
      "text": "函华连龙也不敢打了"
    },
    {
      "start_seconds": 128,
      "end_seconds": 129,
      "text": "这把亏损最大化"
    },
    {
      "start_seconds": 129,
      "end_seconds": 130,
      "text": "每一步都走错"
    },
    {
      "start_seconds": 130,
      "end_seconds": 131,
      "text": "也是需要技术含量的吧"
    },
    {
      "start_seconds": 131,
      "end_seconds": 132,
      "text": "被这样侮辱我"
    },
    {
      "start_seconds": 132,
      "end_seconds": 134,
      "text": "哪位哥在牢皮捞的时候"
    },
    {
      "start_seconds": 134,
      "end_seconds": 135,
      "text": "哪受过这个罪"
    },
    {
      "start_seconds": 135,
      "end_seconds": 135,
      "text": "见到欧呢"
    },
    {
      "start_seconds": 135,
      "end_seconds": 136,
      "text": "就是一个二连"
    },
    {
      "start_seconds": 136,
      "end_seconds": 137,
      "text": "有没有队友不知道"
    },
    {
      "start_seconds": 137,
      "end_seconds": 138,
      "text": "先冲上去再说"
    },
    {
      "start_seconds": 138,
      "end_seconds": 140,
      "text": "乐后三级怎么了"
    },
    {
      "start_seconds": 140,
      "end_seconds": 141,
      "text": "就问这不干没干你吧"
    },
    {
      "start_seconds": 141,
      "end_seconds": 143,
      "text": "既然你函华不敢打龙"
    },
    {
      "start_seconds": 143,
      "end_seconds": 144,
      "text": "那我T万打"
    },
    {
      "start_seconds": 144,
      "end_seconds": 145,
      "text": "这时候你再看我哪位哥在干啥"
    },
    {
      "start_seconds": 145,
      "end_seconds": 147,
      "text": "大龙坑没视野"
    },
    {
      "start_seconds": 147,
      "end_seconds": 148,
      "text": "上下路T万也没人待"
    },
    {
      "start_seconds": 148,
      "end_seconds": 150,
      "text": "就这也要直奔自家的蓝BUFF"
    },
    {
      "start_seconds": 150,
      "end_seconds": 151,
      "text": "这蓝还没打完"
    },
    {
      "start_seconds": 151,
      "end_seconds": 153,
      "text": "就打的进攻合道的信号"
    },
    {
      "start_seconds": 153,
      "end_seconds": 155,
      "text": "要兄弟们全体进攻7万的F6"
    },
    {
      "start_seconds": 155,
      "end_seconds": 157,
      "text": "这时候双技就开始往河道这边靠"
    },
    {
      "start_seconds": 157,
      "end_seconds": 159,
      "text": "于是同时Delete就有点哥哥不入了"
    },
    {
      "start_seconds": 159,
      "end_seconds": 160,
      "text": "就是不听话"
    },
    {
      "start_seconds": 160,
      "end_seconds": 161,
      "text": "非要去龙坑给个眼"
    },
    {
      "start_seconds": 161,
      "end_seconds": 162,
      "text": "这下好了"
    },
    {
      "start_seconds": 162,
      "end_seconds": 164,
      "text": "7万的F6那是没有机会看上一眼了"
    },
    {
      "start_seconds": 164,
      "end_seconds": 166,
      "text": "我纳维哥很事不爽"
    },
    {
      "start_seconds": 166,
      "end_seconds": 166,
      "text": "卑鄙不耐"
    },
    {
      "start_seconds": 166,
      "end_seconds": 168,
      "text": "只能往中路靠意思一下"
    },
    {
      "start_seconds": 168,
      "end_seconds": 169,
      "text": "这大龙都没了"
    },
    {
      "start_seconds": 169,
      "end_seconds": 172,
      "text": "这下没理由不跟着我纳维哥去反F6了吧"
    },
    {
      "start_seconds": 172,
      "end_seconds": 172,
      "text": "你没看错"
    },
    {
      "start_seconds": 172,
      "end_seconds": 174,
      "text": "我纳维哥最终还是没忍住"
    },
    {
      "start_seconds": 174,
      "end_seconds": 176,
      "text": "又往7万的F6转了一圈"
    },
    {
      "start_seconds": 176,
      "end_seconds": 178,
      "text": "看到我纳维哥是机油机板的走位"
    },
    {
      "start_seconds": 178,
      "end_seconds": 179,
      "text": "谁能帮得住呀"
    },
    {
      "start_seconds": 179,
      "end_seconds": 180,
      "text": "兄弟们"
    },
    {
      "start_seconds": 180,
      "end_seconds": 183,
      "text": "这打韩华像是斗小孩一样稍微动向脑子就行了"
    },
    {
      "start_seconds": 183,
      "end_seconds": 185,
      "text": "哥几个是彻底放飞自我了"
    },
    {
      "start_seconds": 185,
      "end_seconds": 186,
      "text": "配子先溢上去再闪回来"
    },
    {
      "start_seconds": 186,
      "end_seconds": 188,
      "text": "不要让一边微型走位"
    },
    {
      "start_seconds": 188,
      "end_seconds": 189,
      "text": "被Wayne抽了一阵把他多烂"
    },
    {
      "start_seconds": 189,
      "end_seconds": 190,
      "text": "也想露一手闪线派五个"
    },
    {
      "start_seconds": 190,
      "end_seconds": 192,
      "text": "没想到这直接闪到了皇子EQ上"
    },
    {
      "start_seconds": 192,
      "end_seconds": 193,
      "text": "露露再给你一个打招"
    },
    {
      "start_seconds": 193,
      "end_seconds": 195,
      "text": "反倒是让我兰子哥拉了个大的"
    },
    {
      "start_seconds": 195,
      "end_seconds": 196,
      "text": "这打到三十多分钟了"
    },
    {
      "start_seconds": 196,
      "end_seconds": 198,
      "text": "温头刷野也刷不过毛泽"
    },
    {
      "start_seconds": 198,
      "end_seconds": 200,
      "text": "我纳维哥就想蹭点线上的兵线齿"
    },
    {
      "start_seconds": 200,
      "end_seconds": 202,
      "text": "这要不是攻速比AD慢了"
    },
    {
      "start_seconds": 202,
      "end_seconds": 203,
      "text": "最后这俩兵都那是我纳维哥的"
    },
    {
      "start_seconds": 203,
      "end_seconds": 205,
      "text": "有了上班被K炮车的惊艳"
    },
    {
      "start_seconds": 205,
      "end_seconds": 207,
      "text": "那这边炮车县就有惊艳了"
    },
    {
      "start_seconds": 207,
      "end_seconds": 209,
      "text": "扫描一看故意A凉下停手"
    },
    {
      "start_seconds": 209,
      "end_seconds": 210,
      "text": "看似是在让演的前"
    },
    {
      "start_seconds": 210,
      "end_seconds": 212,
      "text": "实则是为了让姑妈卡平位"
    },
    {
      "start_seconds": 212,
      "end_seconds": 214,
      "text": "自己在头门把炮车给吃了"
    },
    {
      "start_seconds": 214,
      "end_seconds": 215,
      "text": "吃完了县上的冰"
    },
    {
      "start_seconds": 215,
      "end_seconds": 216,
      "text": "就立马再去野区巡视下"
    },
    {
      "start_seconds": 216,
      "end_seconds": 219,
      "text": "这不是想投个哈马都没有一点机会"
    },
    {
      "start_seconds": 219,
      "end_seconds": 220,
      "text": "吃完县上吃野区"
    },
    {
      "start_seconds": 220,
      "end_seconds": 224,
      "text": "哪位都这样吸血的经济也就只比自家辅助高"
    },
    {
      "start_seconds": 224,
      "end_seconds": 226,
      "text": "就连对面的辅助都能压他一头"
    },
    {
      "start_seconds": 226,
      "end_seconds": 227,
      "text": "这谁能奔得住呀"
    },
    {
      "start_seconds": 227,
      "end_seconds": 228,
      "text": "打到32分钟"
    },
    {
      "start_seconds": 228,
      "end_seconds": 230,
      "text": "路先滑到姑妈脸上就是两项"
    },
    {
      "start_seconds": 230,
      "end_seconds": 232,
      "text": "这直接掉了三分之二的钱"
    },
    {
      "start_seconds": 232,
      "end_seconds": 233,
      "text": "这还怎么打"
    },
    {
      "start_seconds": 233,
      "end_seconds": 236,
      "text": "我鸡蛋哥也是赛前学我冰哥贷款全剩多关"
    },
    {
      "start_seconds": 236,
      "end_seconds": 237,
      "text": "这下好了"
    },
    {
      "start_seconds": 237,
      "end_seconds": 238,
      "text": "第二天就0-2输给了老东家"
    },
    {
      "start_seconds": 238,
      "end_seconds": 241,
      "text": "你这心一分和我冰哥的也没法比呀"
    },
    {
      "start_seconds": 241,
      "end_seconds": 244,
      "text": "估计是以前刷我飞哥的信用卡刷习惯了"
    },
    {
      "start_seconds": 244,
      "end_seconds": 245,
      "text": "一换到卡拉位的发现"
    },
    {
      "start_seconds": 245,
      "end_seconds": 248,
      "text": "他怎么已经进入黑名单了呀"
    }
  ]
}