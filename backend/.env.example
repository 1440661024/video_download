# --- 运行环境 ---
APP_ENV=production

# --- 已有 AI / 下载相关 ---
AI_API_KEY=
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# --- 数据库（默认 SQLite 文件在 backend/data/app.db）---
# DATABASE_URL=sqlite:///C:/path/to/app.db

# --- 鉴权（生产务必改为随机长串）---
JWT_SECRET=change-me-to-a-long-random-string

# --- Stripe（测试模式：https://dashboard.stripe.com/test/apikeys）---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# 可选：在 Stripe Dashboard 创建 CNY 一次性 Price 后填写，否则使用下方金额的内联 price_data
# STRIPE_PRICE_ID=price_...
STRIPE_MEMBERSHIP_CNY_MINOR_UNITS=990

# --- 前端回调（与 Vite 开发地址一致；生产改为真实域名）---
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- 会员时长（天）---
AI_MEMBERSHIP_DAYS=30

# --- Cookie：仅 HTTPS 生产环境设为 true ---
COOKIE_SECURE=false

# --- FFmpeg（留空则自动从系统 PATH 查找）---
FFMPEG_LOCATION=

# --- ASR（Linux 服务器一般建议先用 CPU 配置）---
ASR_MODEL_SIZE=base
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
ASR_BEAM_SIZE=1
